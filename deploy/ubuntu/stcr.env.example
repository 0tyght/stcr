# Copy to /etc/stcr/stcr.env, replace every placeholder, then chmod 600.
# Never commit the real file.
STCR_DB_HOST=127.0.0.1
STCR_DB_PORT=3306
STCR_DB_USER=stcr_app
STCR_DB_PASSWORD=replace-with-a-random-database-password
STCR_DB_NAME=stcr
STCR_ALLOWED_ORIGINS=https://stcr.example.com
STCR_DEPLOYMENT_MODE=production
STCR_SESSION_TTL_MINUTES=480
STCR_OFFLINE_THRESHOLD_SECONDS=180
STCR_TRUST_PROXY=true
STCR_NODE_RED_CREDENTIAL_SECRET=replace-with-at-least-32-random-characters
STCR_API_KEY_PEPPER=replace-with-at-least-32-random-characters
STCR_GR_INGEST_API_KEY=replace-with-the-issued-gr-key
STCR_TTN_INGEST_API_KEY=replace-with-the-issued-ttn-key
STCR_HTTP_INGEST_ENABLED=true
STCR_INGEST_URL=http://127.0.0.1:1880/stcr/api/telemetry
STCR_FACTORY_MQTT_ENABLED=true
STCR_FACTORY_MQTT_FORWARD_ENABLED=false
STCR_FACTORY_MQTT_URL=mqtts://mqtt.example.com:8883
STCR_FACTORY_MQTT_USERNAME=replace-with-mqtt-username
STCR_FACTORY_MQTT_PASSWORD=replace-with-mqtt-password
STCR_FACTORY_MQTT_COMPANY_ID=ttn
STCR_FACTORY_MQTT_TOPICS=test,sensor
STCR_FACTORY_MQTT_CLIENT_ID=stcr-production-server
STCR_FACTORY_MQTT_OVEN_MAP_JSON='{"1":"oven-1","2":"oven-2","3":"oven-3","4":"oven-4","5":"oven-5","6":"oven-6","7":"oven-7","8":"oven-8","9":"oven-9"}'
STCR_FACTORY_MQTT_SOURCE_UTC_OFFSET_MINUTES=420
STCR_REPORT_READY_HOLD_SECONDS=1800
STCR_FACTORY_MQTT_TLS_REJECT_UNAUTHORIZED=true
STCR_FACTORY_MQTT_RAW_URL=http://127.0.0.1:1880/stcr/api/factory-mqtt/raw
STCR_BACKUP_RETENTION_DAYS=14
