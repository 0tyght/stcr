{
  "name": "stcr-redesign",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=24.7.0"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "node-red:build": "node node-red/build-flow.mjs",
    "node-red:validate": "node node-red/validate-flow.mjs",
    "test:mqtt-lifecycle": "node scripts/test-mqtt-lifecycle.mjs",
    "production:preflight": "node scripts/production-preflight.mjs",
    "db:migrate": "node scripts/migrate-database.mjs",
    "db:backup": "powershell -ExecutionPolicy Bypass -File ./scripts/backup-database.ps1",
    "db:secure": "powershell -ExecutionPolicy Bypass -File ./scripts/secure-test-database.ps1",
    "public:start": "powershell -ExecutionPolicy Bypass -File ./scripts/start-public-test.ps1",
    "public:stop": "powershell -ExecutionPolicy Bypass -File ./scripts/stop-public-test.ps1"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "echarts": "^6.0.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.546.0",
    "mqtt": "^5.15.2",
    "mysql2": "^3.23.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.9.4"
  },
  "devDependencies": {
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "typescript": "^5.9.3",
    "vite": "^8.1.5"
  }
}
