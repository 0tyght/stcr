# Node-RED HTTP In base URL. A relative URL is recommended when both systems share a host.
VITE_API_BASE_URL=http://127.0.0.1:1880/stcr/api

# Optional company-specific sources. When omitted, VITE_API_BASE_URL is used.
VITE_GR_API_BASE_URL=http://127.0.0.1:1880/stcr/api
VITE_TTN_API_BASE_URL=http://127.0.0.1:1880/stcr/api

# Realtime polling and HTTP timeout in milliseconds.
VITE_REALTIME_POLL_INTERVAL_MS=5000
VITE_API_TIMEOUT_MS=10000

# Security values below belong to the Node-RED process, not the Vite frontend.
# Never use VITE_* for passwords, hashes, database credentials, or session secrets.
# Users, roles and account status are stored in MySQL. Generate an Argon2id user with:
# node node-red/create-user.mjs gr gr_admin admin "GR Administrator"
# STCR_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
# STCR_DEPLOYMENT_MODE=development
# STCR_SESSION_TTL_MINUTES=480
# STCR_OFFLINE_THRESHOLD_SECONDS=180
# STCR_TRUST_PROXY=false
# STCR_DB_HOST=127.0.0.1
# STCR_DB_PORT=3306
# STCR_DB_USER=stcr_app
# STCR_DB_PASSWORD=change-this-before-using-node-red-mode
# STCR_DB_NAME=stcr
# Keep this pepper outside Git. It is used to HMAC API keys before database comparison.
# STCR_API_KEY_PEPPER=use-at-least-32-random-characters
# STCR_NODE_RED_CREDENTIAL_SECRET=use-at-least-32-random-characters
# Create separate keys per company after setting the pepper:
# node node-red/create-api-key.mjs gr "GR Node-RED gateway"
# node node-red/create-api-key.mjs ttn "TTN Node-RED gateway"
# STCR_GR_INGEST_API_KEY=stcr_gr_secret-shown-once
# STCR_TTN_INGEST_API_KEY=stcr_ttn_secret-shown-once
# STCR_HTTP_INGEST_ENABLED=true

# Factory MQTT input. Keep forwarding false until company and oven mappings are verified.
# STCR_FACTORY_MQTT_ENABLED=false
# STCR_FACTORY_MQTT_URL=mqtt://broker.example.com:1883
# STCR_FACTORY_MQTT_USERNAME=replace-with-mqtt-username
# STCR_FACTORY_MQTT_PASSWORD=replace-with-mqtt-password
# STCR_FACTORY_MQTT_COMPANY_ID=ttn
# STCR_FACTORY_MQTT_TOPICS=test,sensor
# STCR_FACTORY_MQTT_CLIENT_ID=stcr-ttn-server
# TTN has ovens 1-9. Keep this mapping explicit so an unexpected oven is rejected.
# STCR_FACTORY_MQTT_OVEN_MAP_JSON={"1":"oven-1","2":"oven-2","3":"oven-3","4":"oven-4","5":"oven-5","6":"oven-6","7":"oven-7","8":"oven-8","9":"oven-9"}
# Preferred multi-company configuration (takes precedence over COMPANY_ID/TOPICS/OVEN_MAP_JSON):
# STCR_FACTORY_MQTT_TOPIC_ROUTES_JSON={"test":{"companyId":"ttn","messageType":"status"},"sensor":{"companyId":"ttn","messageType":"sensor"},"status_gr":{"companyId":"gr","messageType":"status"},"sensor_gr":{"companyId":"gr","messageType":"sensor"}}
# STCR_FACTORY_MQTT_OVEN_MAPS_JSON={"ttn":{"1":"oven-1","2":"oven-2","3":"oven-3","4":"oven-4","5":"oven-5","6":"oven-6","7":"oven-7","8":"oven-8","9":"oven-9"},"gr":{"11":"oven-11","12":"oven-12","13":"oven-13","14":"oven-14","15":"oven-15","16":"oven-16","17":"oven-17","18":"oven-18","19":"oven-19","20":"oven-20","21":"oven-21","22":"oven-22","23":"oven-23","24":"oven-24","25":"oven-25","26":"oven-26"}}
# The current TTN publisher sends Bangkok wall-clock time with a trailing Z; subtract 420 minutes.
# STCR_FACTORY_MQTT_SOURCE_UTC_OFFSET_MINUTES=420
# Broad physical safety bounds. Values outside these ranges are quarantined,
# not displayed and not included in minute averages or reports.
# STCR_FACTORY_MQTT_SENSOR_RANGES_JSON={"chamberTemp":{"min":-40,"max":150},"humidity":{"min":0,"max":100},"furnaceTemp":{"min":-40,"max":1000},"blowerTemp":{"min":-40,"max":600}}
# STCR_FACTORY_MQTT_OUT_OF_ORDER_TOLERANCE_MS=2000
# STCR_FACTORY_MQTT_STORE_RAW_MESSAGES=false
# STCR_FACTORY_MQTT_TLS_REJECT_UNAUTHORIZED=true
# STCR_FACTORY_MQTT_RAW_URL=http://127.0.0.1:1880/stcr/api/factory-mqtt/raw
