# mock | node-red
VITE_DATA_SOURCE=mock

# Node-RED HTTP In base URL. A relative URL is recommended when both systems share a host.
VITE_API_BASE_URL=http://127.0.0.1:1880/stcr/api

# Optional company-specific sources. When omitted, VITE_API_BASE_URL is used.
VITE_GR_API_BASE_URL=http://127.0.0.1:1880/stcr/api
VITE_TTN_API_BASE_URL=http://127.0.0.1:1880/stcr/api

# Realtime polling and HTTP timeout in milliseconds.
VITE_REALTIME_POLL_INTERVAL_MS=5000
VITE_API_TIMEOUT_MS=10000

# Security values below belong to the Node-RED process, not the Vite frontend.
# Never use VITE_* for passwords, hashes, database credentials, or session secrets.
# Generate passwordHash with: node node-red/hash-password.mjs
# STCR_AUTH_USERS_JSON={"gr_dev_admin":{"companyId":"gr","passwordHash":"pbkdf2$sha256$310000$...$..."},"ttn_dev_admin":{"companyId":"ttn","passwordHash":"pbkdf2$sha256$310000$...$..."}}
# STCR_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
# STCR_SESSION_TTL_MINUTES=480
# STCR_TRUST_PROXY=false
# STCR_DB_HOST=127.0.0.1
# STCR_DB_PORT=3306
# STCR_DB_USER=stcr_app
# STCR_DB_PASSWORD=change-this-before-using-node-red-mode
# STCR_DB_NAME=stcr
